# Han Empire environment example (v5.1.5 P5-2)
# Copy this file to .env and fill in your own values before running the game.
# .env is gitignored; never commit your real key.

# Required: OpenAI-compatible Chat Completions API key.
# Han Empire v5.1.x supports MINIMAX_API_KEY / OPENAI_API_KEY / DEEPSEEK_API_KEY
# (checked in this order in han_sim/llm_router.py + llm_config.py).
# Set exactly one of them.
MINIMAX_API_KEY=your_minimax_key_here
# OPENAI_API_KEY=your_openai_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional: API endpoint and model.
# Recommended: deepseek-v4-flash (cheap + fast, works well for Han narrative).
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# Optional: per-request timeout for LLM calls, in seconds.
OPENAI_TIMEOUT_SECONDS=180

# Optional: advanced model for the heaviest LLM steps (verdict extractor,
# court debate summary). Leave empty to reuse OPENAI_MODEL.
# OPENAI_ADVANCED_MODEL=

# Optional: server port (Flask). Default 5555.
# PORT=5555

# Optional: SQLite database directory. The app creates campaign_*.db inside
# this directory automatically.
# HAN_EMPIRE_DB_DIR=data

# Optional: random seed for event sampling.
# HAN_EMPIRE_SEED=7

# Optional: automated playtest overrides used by scripts/auto_play_v51.py
# (v5.1.5 P5-3 balance test). Leave empty to reuse OPENAI_* values.
# PLAYTEST_API_KEY=
# PLAYTEST_BASE_URL=https://api.deepseek.com
# PLAYTEST_MODEL=deepseek-v4-flash
